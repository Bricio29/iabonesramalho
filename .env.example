# =============================================================
#  CONFIGURAÇÃO — IA Bonés Ramalho (ChatClean)
# =============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- ChatClean PUSH API ---
# URL autenticada gerada em Configurações → API/Webhook → Adicionar
# O token JWT já está embutido na URL como query param (?token=...)
CC_PUSH_URL=https://betaapi.chatclean.com.br/v1/api/external/SEU-UUID/?token=SEU-JWT

# URL pública deste servidor (sem barra no final)
# Necessária para servir as imagens dos produtos ao ChatClean via mediaUrl
# Exemplos:
#   https://seudominio.com.br
#   http://123.456.789.10:3000
BASE_URL=https://seudominio.com.br

# Segredo para validar as requisições do webhook (opcional, mas recomendado)
# Configure o mesmo valor no painel do ChatClean como "Token de autenticação"
WEBHOOK_SECRET=

# --- Servidor ---
PORT=3000

# --- Equipe interna ---
# Número do WhatsApp da equipe que receberá notificações de leads qualificados
# Formato: apenas dígitos (DDI + DDD + número)
EQUIPE_NUMERO=5584999999999
